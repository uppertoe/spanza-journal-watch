# /etc/restic/env — Backup environment for Journal Watch.
#
# Copy to /etc/restic/env and fill in real values.
# Permissions must be 600 (readable by root only):
#   chmod 600 /etc/restic/env
#
# Generate RESTIC_PASSWORD with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Store it somewhere safe (password manager) — losing it means losing
# access to all backups.

# ---------------------------------------------------------------------------
# Restic
# ---------------------------------------------------------------------------
RESTIC_REPOSITORY=s3:s3.amazonaws.com/your-bucket-name/backups
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
RESTIC_PASSWORD=change-me-store-this-safely

# ---------------------------------------------------------------------------
# AWS (required for S3 repository)
# ---------------------------------------------------------------------------
# Recommendation: use a dedicated IAM user with s3:GetObject, s3:PutObject,
# s3:DeleteObject, and s3:ListBucket permissions scoped to the bucket prefix.
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_DEFAULT_REGION=ap-southeast-2

# ---------------------------------------------------------------------------
# Django PostgreSQL
# ---------------------------------------------------------------------------
# These must match .envs/.production/.postgres.
# POSTGRES_HOST points to 127.0.0.1 because the VPS backup script connects
# via the host-exposed port, not the Docker network.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=spanza_journal_watch
POSTGRES_USER=change-me-db-user
POSTGRES_PASSWORD=change-me-db-password

# ---------------------------------------------------------------------------
# Planka PostgreSQL
# ---------------------------------------------------------------------------
# Planka's postgres uses trust auth — no password required.
# Port 5433 is the host-side binding; see minimal.dockerhub.yml.
PLANKA_DB_HOST=127.0.0.1
PLANKA_DB_PORT=5433

# ---------------------------------------------------------------------------
# Retention
# ---------------------------------------------------------------------------
KEEP_DAILY=7
KEEP_WEEKLY=4
KEEP_MONTHLY=6

# ---------------------------------------------------------------------------
# Notifications (Amazon SES SMTP)
# ---------------------------------------------------------------------------
# SES SMTP credentials are separate from IAM credentials.
# Create them in the AWS console: SES → SMTP settings → Create credentials.
ALERT_EMAIL=admin@yourdomain.com
SMTP_HOST=email-smtp.ap-southeast-2.amazonaws.com
SMTP_PORT=587
SMTP_TLS=on
SMTP_USER=change-me-ses-smtp-user
SMTP_PASSWORD=change-me-ses-smtp-password
SMTP_FROM=backup@yourdomain.com

# Set to "true" to receive an email on successful backup as well as failure.
# Leave as "false" to only be notified on failure.
NOTIFY_ON_SUCCESS=false
