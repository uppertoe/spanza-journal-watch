# =============================================================================
# SPANZA Journal Watch — production environment
#
# Recommended: generate a fully populated .env automatically:
#
#   bash ops/gen-env.sh
#
# Or copy this file manually and fill in every value:
#
#   cp .env.example .env
#
# Lines beginning with # are comments and are ignored.
# =============================================================================


# =============================================================================
# Docker Hub
# =============================================================================

DOCKERHUB_NAMESPACE=your-dockerhub-namespace
APP_TAG=latest


# =============================================================================
# Django
# =============================================================================

DJANGO_SETTINGS_MODULE=config.settings.production

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=change-me-generate-a-strong-random-key

# Obfuscate the Django admin URL — use a random path segment
DJANGO_ADMIN_URL=change-me-random-path/

# Comma-separated list of allowed hostnames (no spaces)
DJANGO_ALLOWED_HOSTS=[".yourdomain.com"]

# Set False when TLS is terminated upstream (nginx, Caddy, ALB, etc.)
DJANGO_SECURE_SSL_REDIRECT=False

DJANGO_SERVER_EMAIL="Journal Watch <noreply@yourdomain.com>"
DJANGO_DEFAULT_FROM_EMAIL="Journal Watch <noreply@yourdomain.com>"

DJANGO_ACCOUNT_ALLOW_REGISTRATION=True

# Gunicorn workers — rule of thumb: 2 × CPU cores + 1
WEB_CONCURRENCY=3


# =============================================================================
# PostgreSQL (Django database)
# =============================================================================

POSTGRES_DB=spanza_journal_watch
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_USER=change-me-db-user
POSTGRES_PASSWORD=change-me-strong-db-password


# =============================================================================
# AWS
# =============================================================================

DJANGO_AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
DJANGO_AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
DJANGO_AWS_STORAGE_BUCKET_NAME=your-bucket-name
DJANGO_AWS_S3_REGION_NAME=ap-southeast-2
DJANGO_AWS_DEFAULT_REGION=ap-southeast-2


# =============================================================================
# Amazon SES (transactional email)
# =============================================================================

# Signing secret for the SES SNS webhook subscription
WEBHOOK_SECRET=change-me-ses-webhook-signing-secret

# SES configuration set name — default is TrackingConfigSet (prod).
# Override for staging: ANYMAIL_CONFIGURATION_SET_NAME=TrackingConfigSet-staging
ANYMAIL_CONFIGURATION_SET_NAME=TrackingConfigSet

# Prefix for S3-stored inbound email objects
DJANGO_ANYMAIL_INBOUND_S3_OBJECT_PREFIX=email


# =============================================================================
# Celery / Flower
# =============================================================================

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
CELERY_FLOWER_USER=change-me-flower-user
CELERY_FLOWER_PASSWORD=change-me-flower-password


# =============================================================================
# Sentry (optional — leave blank to disable)
# =============================================================================

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1


# =============================================================================
# OIDC — Django as OAuth2/OIDC provider for Planka
# =============================================================================

# Base64-encoded RSA private key. Generate with:
#   openssl genrsa 4096 | base64 -w 0
OIDC_RSA_PRIVATE_KEY=

# Issuer URL — must be the public URL of the Django OIDC endpoint
OIDC_ISS_ENDPOINT=https://yourdomain.com/o


# =============================================================================
# Planka integration (Django → Planka API)
# =============================================================================

# Public URL where Planka is reachable (used for links in the Django UI)
PLANKA_EXTERNAL_URL=https://planka.yourdomain.com

# Must match DEFAULT_ADMIN_EMAIL below
PLANKA_ADMIN_EMAIL=admin@yourdomain.com


# =============================================================================
# Planka application
# =============================================================================

BASE_URL=https://planka.yourdomain.com
DATABASE_URL=postgresql://postgres@planka_postgres/planka

# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Increment whenever terms content changes to prompt re-acceptance
USER_TERMS_OF_SERVICE_VERSION=1

# OIDC — run `manage.py setup_planka_oidc` once after first boot
# OIDC_ISSUER is set automatically by compose from OIDC_ISS_ENDPOINT above.
OIDC_CLIENT_ID=planka-production
# Generate with: openssl rand -hex 32; must match the client created by setup_planka_oidc
OIDC_CLIENT_SECRET=change-me-strong-random-secret
OIDC_USE_DEFAULT_RESPONSE_MODE=true
OIDC_SCOPES=openid email profile
OIDC_EMAIL_ATTRIBUTE=email
OIDC_NAME_ATTRIBUTE=name
OIDC_IGNORE_USERNAME=true
OIDC_IGNORE_ROLES=true
# Enable AFTER running setup_planka_api_key from the backend settings UI.
# Uncomment and restart Planka to enforce SSO login.
# OIDC_ENFORCED=true

# Admin bootstrap — used only by `manage.py setup_planka_api_key`
# DEFAULT_ADMIN_EMAIL is set automatically by compose from PLANKA_ADMIN_EMAIL above.
DEFAULT_ADMIN_NAME=Journal Watch Admin
DEFAULT_ADMIN_USERNAME=admin
# Set once at first boot, then remove
DEFAULT_ADMIN_PASSWORD=change-me-then-remove


# =============================================================================
# Planka — S3 object storage
# Use a SEPARATE IAM user and a SEPARATE bucket for Planka.
# This avoids Planka writes overlapping with Django media/email/backups.
# See docs/operations/aws-setup.md for the required IAM policy.
# =============================================================================

PLANKA_S3_BUCKET=your-planka-bucket-name
PLANKA_S3_ACCESS_KEY_ID=REPLACE_WITH_PLANKA_IAM_ACCESS_KEY
PLANKA_S3_SECRET_ACCESS_KEY=REPLACE_WITH_PLANKA_IAM_SECRET_KEY
PLANKA_S3_REGION=ap-southeast-2
