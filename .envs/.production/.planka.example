# Planka — production environment
# ------------------------------------------------------------------------------

# Core
# ------------------------------------------------------------------------------
BASE_URL=https://planka.yourdomain.com
DATABASE_URL=postgresql://postgres@planka_postgres/planka
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
# Increment this version string whenever the terms content changes to prompt re-acceptance
USER_TERMS_OF_SERVICE_VERSION=1

# OIDC — Django acts as the provider (run `manage.py setup_planka_oidc` once)
# ------------------------------------------------------------------------------
OIDC_ISSUER=https://yourdomain.com/o
OIDC_CLIENT_ID=planka-production
# Must match the client secret created by `manage.py setup_planka_oidc`
# Generate with: openssl rand -hex 32
OIDC_CLIENT_SECRET=change-me-strong-random-secret
OIDC_USE_DEFAULT_RESPONSE_MODE=true
OIDC_SCOPES=openid email profile
OIDC_EMAIL_ATTRIBUTE=email
OIDC_NAME_ATTRIBUTE=name
OIDC_IGNORE_USERNAME=true
OIDC_IGNORE_ROLES=true
# Enable AFTER running setup_planka_api_key from the backend settings UI.
# That command performs an admin login to initialise the instance, which is required
# before SSO users can authenticate. Uncomment and restart Planka to enforce SSO.
# OIDC_ENFORCED=true

# Admin bootstrap — used only by `manage.py setup_planka_api_key`
# ------------------------------------------------------------------------------
DEFAULT_ADMIN_EMAIL=admin@yourdomain.com
DEFAULT_ADMIN_NAME=Journal Watch Admin
DEFAULT_ADMIN_USERNAME=admin
# Set once at first boot, then remove or leave unset
DEFAULT_ADMIN_PASSWORD=change-me-then-remove

# S3 — attachments storage
# Use the same bucket as Django (DJANGO_AWS_STORAGE_BUCKET_NAME).
# S3_ACCESS_KEY_ID  == DJANGO_AWS_ACCESS_KEY_ID
# S3_SECRET_ACCESS_KEY == DJANGO_AWS_SECRET_ACCESS_KEY
# S3_REGION         == DJANGO_AWS_S3_REGION_NAME
# S3_BUCKET         == DJANGO_AWS_STORAGE_BUCKET_NAME
# Planka writes under the prefix "attachments/" inside the bucket automatically.
# Leave S3_ENDPOINT blank for standard AWS S3; set it for MinIO or custom endpoints.
# S3_FORCE_PATH_STYLE should be false for AWS, true for MinIO/path-style endpoints.
# ------------------------------------------------------------------------------
S3_ENDPOINT=
S3_REGION=ap-southeast-2
S3_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
S3_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
S3_BUCKET=your-bucket-name
S3_FORCE_PATH_STYLE=false
