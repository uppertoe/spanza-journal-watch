# =============================================================================
# Journal Watch — app environment for vps-base-template server repo
# Place at apps/journalwatch/.env (never commit the populated file).
#
# Before running docker compose, load this file into the shell so that
# variable substitutions in docker-compose.yml work correctly:
#
#   set -a; source apps/journalwatch/.env; set +a
#   docker compose --profile workers --profile planka up -d
# =============================================================================


# =============================================================================
# Docker Hub
# =============================================================================

JW_DOCKERHUB_NAMESPACE=your-dockerhub-namespace
JW_APP_TAG=latest


# =============================================================================
# Django
# =============================================================================

DJANGO_SETTINGS_MODULE=config.settings.production

# python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=

# Comma-separated allowed hostnames
DJANGO_ALLOWED_HOSTS=".journalwatch.org.au"

# TLS is terminated by Caddy — keep False
DJANGO_SECURE_SSL_REDIRECT=False

DJANGO_DEFAULT_FROM_EMAIL="Journal Watch <noreply@journalwatch.org.au>"
DJANGO_SERVER_EMAIL="Journal Watch <noreply@journalwatch.org.au>"

# Obfuscate the admin URL with a random path segment
DJANGO_ADMIN_URL=change-me-random-path/

DJANGO_ACCOUNT_ALLOW_REGISTRATION=True

# Gunicorn workers — rule of thumb: 2 × CPU cores + 1
WEB_CONCURRENCY=3


# =============================================================================
# PostgreSQL (Django database)
# =============================================================================

POSTGRES_DB=spanza_journal_watch
POSTGRES_USER=jw
# python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=


# =============================================================================
# AWS (S3 media storage + SES transactional email)
# =============================================================================

DJANGO_AWS_ACCESS_KEY_ID=
DJANGO_AWS_SECRET_ACCESS_KEY=
DJANGO_AWS_STORAGE_BUCKET_NAME=your-bucket-name
DJANGO_AWS_S3_REGION_NAME=ap-southeast-2
DJANGO_AWS_DEFAULT_REGION=ap-southeast-2

# S3 prefix for inbound emails stored by SES receive action
DJANGO_ANYMAIL_INBOUND_S3_OBJECT_PREFIX=email

# You generate this value yourself:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Put the same value in the SNS subscription URL that aws_setup.py prints later.
# Django does NOT receive SNS events until you run that aws sns subscribe command.
# This secret lets Django reject unexpected webhook traffic.
WEBHOOK_SECRET=

# SES configuration set — use TrackingConfigSet-staging for staging
ANYMAIL_CONFIGURATION_SET_NAME=TrackingConfigSet


# =============================================================================
# Celery / Flower
# =============================================================================

# python -c "import secrets; print(secrets.token_urlsafe(16))"
CELERY_FLOWER_USER=flower
CELERY_FLOWER_PASSWORD=


# =============================================================================
# Sentry (optional — leave blank to disable)
# =============================================================================

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1


# =============================================================================
# OIDC — Django as OAuth2/OIDC provider for Planka
# =============================================================================

# Base64-encoded RSA private key:
#   openssl genrsa 4096 | base64 -w 0
OIDC_RSA_PRIVATE_KEY=

# Public URL of the Django OIDC endpoint (must be reachable by Planka)
OIDC_ISS_ENDPOINT=https://journalwatch.org.au/o


# =============================================================================
# Planka integration (Django → Planka API)
# =============================================================================

# Public URL where Planka is reachable (used for links in the Django UI)
PLANKA_EXTERNAL_URL=https://planka.journalwatch.org.au

# Must match DEFAULT_ADMIN_EMAIL below
PLANKA_ADMIN_EMAIL=admin@journalwatch.org.au


# =============================================================================
# Planka application
# =============================================================================

BASE_URL=https://planka.journalwatch.org.au

# openssl rand -hex 32
SECRET_KEY=

# python -c "import secrets; print(secrets.token_urlsafe(24))"
PLANKA_POSTGRES_PASSWORD=

USER_TERMS_OF_SERVICE_VERSION=1

OIDC_CLIENT_ID=planka-production
# openssl rand -hex 32  (must match the client created by `manage.py setup_planka_oidc`)
OIDC_CLIENT_SECRET=
OIDC_USE_DEFAULT_RESPONSE_MODE=true
OIDC_SCOPES=openid email profile
OIDC_EMAIL_ATTRIBUTE=email
OIDC_NAME_ATTRIBUTE=name
OIDC_IGNORE_USERNAME=true
OIDC_IGNORE_ROLES=true
# Uncomment AFTER running setup_planka_api_key from the backend settings UI,
# then restart Planka to enforce SSO-only login:
# OIDC_ENFORCED=true

DEFAULT_ADMIN_NAME=Journal Watch Admin
DEFAULT_ADMIN_USERNAME=admin
# Set once at first boot, then remove from this file:
DEFAULT_ADMIN_PASSWORD=


# =============================================================================
# Planka — S3 object storage
# Use a SEPARATE IAM user and a SEPARATE bucket for Planka.
# =============================================================================

PLANKA_S3_BUCKET=
PLANKA_S3_ACCESS_KEY_ID=
PLANKA_S3_SECRET_ACCESS_KEY=
PLANKA_S3_REGION=ap-southeast-2
